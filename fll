# fll - run pyfll as root while preserving the invoking user's uid/gid, so the
# build output (ISO, logs, work dir) is owned by them rather than root.

# Locate pyfll: prefer the source-tree layout, else fall back to PATH.
THIS_DIR=$(dirname "$(readlink -f "$0")")
if [ -x "${THIS_DIR}/bin/pyfll" ]; then
	FLL="${THIS_DIR}/bin/pyfll"
elif command -v pyfll >/dev/null 2>&1; then
	FLL=$(command -v pyfll)
else
	echo "${0##*/}: cannot locate pyfll, aborting." >&2
	exit 1
fi

# --help just prints usage and exits; no privilege needed.
for arg in "$@"; do
	case "${arg}" in
		-h|--help)
			exec "${FLL}" "$@"
			;;
	esac
done

# Already root: run directly.
if [ "$(id -u)" -eq 0 ]; then
	exec "${FLL}" "$@"
fi

# Non-root: capture the caller's ids for pyfll to chown build output back to,
# then elevate. Prefer sudo (passes argv directly); otherwise su, handing argv
# to a tiny 'exec "$@"' shell as positional parameters so arguments survive
# intact. The leading '--' stops su parsing our --uid/--gid/... as its own
# options (which is what broke with util-linux su); the 'fll' token becomes $0.
uid=$(id -u)
gid=$(id -g)

if command -v sudo >/dev/null 2>&1 && id -nG | grep -qw sudo; then
	exec sudo -- "${FLL}" --uid "${uid}" --gid "${gid}" "$@"
else
	exec su --command 'exec "$@"' -- root fll "${FLL}" --uid "${uid}" --gid "${gid}" "$@"
fi
